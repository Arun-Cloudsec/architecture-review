# ============================================================
# ATLAS Review Agent · Configuration
# ============================================================

# ============================================================
# LLM PROVIDER — pick ONE based on your data-residency needs
# ============================================================
# Options:
#   anthropic_direct  → Claude via api.anthropic.com (default, easiest setup)
#   aws_bedrock       → Claude via AWS Bedrock in your region (recommended for banks)
#   azure_openai      → GPT-4 via Azure OpenAI in your region (Azure-first orgs)
#
LLM_PROVIDER=anthropic_direct


# ============================================================
# OPTION A — Anthropic Direct (data routes to Anthropic's API)
# ============================================================
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-opus-4-7


# ============================================================
# OPTION B — AWS Bedrock (Claude in YOUR AWS region, no data egress)
# ============================================================
# Regions with Claude: me-central-1 (UAE) · eu-central-1 · eu-west-1 · eu-west-2
#                      ap-south-1 (Mumbai) · ap-southeast-1 (Singapore) · us-east-1
#
# Credentials resolved by AWS SDK chain: env vars, ~/.aws/credentials, or IAM role.
#
# AWS_REGION=me-central-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0


# ============================================================
# OPTION C — Azure OpenAI (GPT-4 in YOUR Azure region)
# ============================================================
# Regions: uaenorth, westeurope, northeurope, southeastasia, centralindia, etc.
#
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview


# ============================================================
# DATA RESIDENCY — displayed in UI banner
# ============================================================
DATA_REGION=AE-ABU DHABI
DATA_SOVEREIGNTY_NOTE=Processed in tenant region · No cross-border egress


# ============================================================
# PII REDACTION — strip sensitive data BEFORE sending to LLM
# ============================================================
# Set to "true" to enable automatic PII redaction
PII_REDACTION=true


# ============================================================
# GENERAL
# ============================================================
# PORT=3000

